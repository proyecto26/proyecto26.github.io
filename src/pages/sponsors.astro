---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import { getSponsorsGrouped, sponsorPlatforms } from '../data/sponsors';

const sponsorTiers = await getSponsorsGrouped();
const totalSponsors = sponsorTiers.reduce((sum, t) => sum + t.sponsors.length, 0);

// Avatar sizes by tier (higher tiers get bigger logos, like Vue/Nuxt/ESLint)
const tierAvatarSizes: Record<string, { img: string; ring: string; w: number }> = {
  'Platinum Partner': { img: 'w-20 h-20', ring: 'ring-accent-coral', w: 80 },
  'Gold Sponsor': { img: 'w-16 h-16', ring: 'ring-accent-orange', w: 64 },
  'Silver Sponsor': { img: 'w-14 h-14', ring: 'ring-accent-blue', w: 56 },
  'Bronze Sponsor': { img: 'w-12 h-12', ring: 'ring-accent-teal', w: 48 },
  'Supporter': { img: 'w-10 h-10', ring: 'ring-accent-teal', w: 40 },
  'Backer': { img: 'w-8 h-8', ring: 'ring-border-default', w: 32 },
};

const faqs = [
  {
    q: 'Where does the money go?',
    a: '80% goes to development time (maintaining projects, fixing bugs, building features), 10% to hosting and infrastructure, and 10% to community events and outreach. See the breakdown above. For detailed transaction history, visit our Open Collective page.',
  },
  {
    q: 'Are sponsorships tax-deductible?',
    a: 'Tax deductibility depends on your jurisdiction. Contributions through Open Collective are made to the Open Source Collective, a 501(c)(6) fiscal host in the US. Consult your tax advisor for specifics.',
  },
  {
    q: 'Do you offer annual billing?',
    a: 'Yes. Contact us to arrange annual invoicing for Gold and Platinum tiers. Annual sponsors save 17%.',
  },
  {
    q: 'Can I sponsor as a company?',
    a: 'Absolutely! Company sponsorships are a great way to support the tools your team relies on. Bronze+ tiers include logo placement reaching 6.6M+ npm installs per year — all mobile developers actively building apps. Gold and Platinum include consulting hours.',
  },
  {
    q: 'Can I make a one-time donation?',
    a: 'Yes! See our one-time contribution options above, starting at $5. You can also donate via Open Collective, Ko-fi, Buy Me a Coffee, PayPal, or crypto.',
  },
  {
    q: 'Do you offer invoices?',
    a: 'Yes. Open Collective provides automatic invoices for all contributions. For GitHub Sponsors, contact us and we can arrange invoicing.',
  },
  {
    q: 'What if I want to cancel?',
    a: 'Cancel anytime on any platform, no questions asked. We appreciate any support, however long.',
  },
  {
    q: 'How many developers use your projects?',
    a: 'Our flagship package react-native-inappbrowser-reborn has 6.6M+ annual npm downloads. Across all projects we have 7,000+ GitHub stars, 100+ contributors, and an estimated 20,000-40,000 active developers depending on our tools.',
  },
  {
    q: 'Can I sponsor a specific project?',
    a: 'Currently sponsorships support all Proyecto 26 projects. Contact us if you\'d like to discuss project-specific sponsorship.',
  },
];
---

<BaseLayout title="Sponsors - Proyecto 26" description="Support Proyecto 26's open source mission. See our sponsor tiers, current sponsors, and ways to contribute.">
  <Header currentPage="sponsors" />

  <main id="main-content" class="pt-[72px]">
    <!-- Schema.org Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Proyecto 26",
      "url": "https://proyecto26.com",
      "logo": "https://proyecto26.com/img/pro26.png",
      "description": "Open source tools for web, mobile, and game development. Changing the world with small contributions.",
      "founder": {
        "@type": "Person",
        "name": "Juan David Nicholls",
        "url": "https://github.com/jdnichollsc"
      },
      "funding": [
        {
          "@type": "MonetaryGrant",
          "name": "GitHub Sponsors",
          "url": "https://github.com/sponsors/proyecto26",
          "funder": {
            "@type": "Organization",
            "name": "GitHub",
            "url": "https://github.com"
          }
        },
        {
          "@type": "MonetaryGrant",
          "name": "Open Collective",
          "url": "https://opencollective.com/proyecto26",
          "funder": {
            "@type": "Organization",
            "name": "Open Collective",
            "url": "https://opencollective.com"
          }
        }
      ],
      "sameAs": [
        "https://github.com/proyecto26",
        "https://www.youtube.com/@proyecto26",
        "https://www.facebook.com/proyecto26",
        "https://x.com/jdnichollsc",
        "https://linkedin.com/in/jdnichollsc"
      ]
    })} />

    <!-- Hero -->
    <section class="py-16 md:py-24 bg-bg-primary">
      <div class="container">
        <div class="text-center max-w-3xl mx-auto">
          <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-text-primary mb-6" data-animate="fade-up">
            Become a Sponsor
          </h1>
          <p class="text-xl text-text-secondary mb-8" data-animate="fade-up" data-delay="100">
            Your sponsorship keeps 25+ open source projects alive &mdash; tools used by thousands of developers to build mobile apps, games, and web experiences. Help us ship faster, fix bugs sooner, and build what the community needs next.
          </p>

          <!-- Dual-platform CTAs (Vue/ESLint pattern) -->
          <div class="flex flex-wrap items-center justify-center gap-4 mb-12" data-animate="fade-up" data-delay="200">
            <Button href="https://github.com/sponsors/proyecto26" variant="primary" external>
              <i data-lucide="heart" class="w-4 h-4"></i>
              Sponsor on GitHub
            </Button>
            <Button href="https://opencollective.com/proyecto26" variant="secondary" external>
              Donate on Open Collective
            </Button>
          </div>

          {/* Stats */}
          <div class="flex flex-wrap items-center justify-center gap-6 md:gap-8 text-center" data-animate="fade-up" data-delay="300">
            <div>
              <div class="text-3xl font-bold gradient-text">6.6M+</div>
              <div class="text-sm text-text-muted">npm Installs/Year</div>
            </div>
            <div class="w-px h-10 bg-border-default hidden sm:block"></div>
            <div>
              <div class="text-3xl font-bold gradient-text">7,000+</div>
              <div class="text-sm text-text-muted">GitHub Stars</div>
            </div>
            <div class="w-px h-10 bg-border-default hidden sm:block"></div>
            <div>
              <div class="text-3xl font-bold gradient-text">25+</div>
              <div class="text-sm text-text-muted">Active Projects</div>
            </div>
            <div class="w-px h-10 bg-border-default hidden sm:block"></div>
            <div>
              <div class="text-3xl font-bold gradient-text">100+</div>
              <div class="text-sm text-text-muted">Contributors</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Sponsor (Vue pattern: Business vs Individual) -->
    <section class="py-16 bg-bg-secondary">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
          <!-- Business -->
          <div class="bg-bg-card border border-border-default rounded-2xl p-8" data-animate="fade-up">
            <div class="w-12 h-12 rounded-xl bg-bg-hover flex items-center justify-center mb-4">
              <i data-lucide="building-2" class="w-6 h-6 text-accent-coral"></i>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-3">Sponsoring as a Business</h3>
            <p class="text-text-secondary text-sm mb-4">
              Your team probably uses one of our open source projects. Sponsoring ensures continued development and gives you:
            </p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                Priority bug fixes and feature requests
              </li>
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                Direct consulting and support hours
              </li>
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                Brand visibility among our developer community
              </li>
            </ul>
          </div>

          <!-- Individual -->
          <div class="bg-bg-card border border-border-default rounded-2xl p-8" data-animate="fade-up" data-delay="100">
            <div class="w-12 h-12 rounded-xl bg-bg-hover flex items-center justify-center mb-4">
              <i data-lucide="heart" class="w-6 h-6 text-accent-teal"></i>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-3">Sponsoring as an Individual</h3>
            <p class="text-text-secondary text-sm mb-4">
              If our tools have made your work easier or helped you learn something new, consider sponsoring as a sign of appreciation — like buying us a coffee once in a while.
            </p>
            <ul class="space-y-2">
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                Exclusive 1-on-1 meetings and content
              </li>
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                Your name credited in our projects
              </li>
              <li class="flex items-start gap-2 text-sm text-text-secondary">
                <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                Support the open source you rely on
              </li>
            </ul>
          </div>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center justify-center gap-4 mt-12" data-animate="fade-up" data-delay="200">
          <Button href="#tiers" variant="secondary">
            <i data-lucide="arrow-down" class="w-4 h-4"></i>
            See Sponsor Tiers Below
          </Button>
          <Button href="https://github.com/sponsors/proyecto26" variant="primary" external>
            <i data-lucide="heart" class="w-4 h-4"></i>
            Start Sponsoring
          </Button>
        </div>
      </div>
    </section>

    <!-- Meet the Maintainer (M6) -->
    <section class="py-16 bg-bg-primary">
      <div class="container">
        <div class="max-w-3xl mx-auto">
          <div class="bg-bg-card border border-border-default rounded-3xl p-8 md:p-12" data-animate="fade-up">
            <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
              <div class="flex-shrink-0">
                <div class="w-36 h-36 rounded-full overflow-hidden ring-4 ring-accent-coral/30">
                  <img
                    src="/img/jdnichollsc.jpg"
                    alt="Juan David Nicholls"
                    width="144"
                    height="144"
                    loading="lazy"
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
              <div class="text-center md:text-left">
                <h2 class="text-2xl font-bold text-text-primary mb-2">Meet the Maintainer</h2>
                <p class="text-text-secondary mb-6">
                  "Hi, I'm Juan David Nicholls. I've been building open source tools since 2015 from Colombia. Your sponsorship lets me dedicate real time to maintaining and improving these projects instead of taking on unrelated contract work. Every dollar goes directly to development."
                </p>
                <Button href="https://github.com/sponsors/proyecto26" variant="primary" external>
                  <i data-lucide="heart" class="w-4 h-4"></i>
                  Sponsor J.D.'s Work
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Sponsor Tiers with scaled logos (Nuxt/ESLint pattern) -->
    <section id="tiers" class="py-16 bg-bg-primary">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Sponsor Tiers
          </h2>
          <p class="text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Choose a tier that works for you. Every contribution counts.
          </p>
        </div>

        <div class="space-y-16 max-w-4xl mx-auto">
          {sponsorTiers.map((tier, tierIndex) => {
            const sizes = tierAvatarSizes[tier.name] || tierAvatarSizes['Backers'];
            const isHighTier = tier.name === 'Gold Sponsor' || tier.name === 'Platinum Partner';
            return (
              <div data-animate="fade-up" data-delay={tierIndex * 80}>
                {/* Tier Header */}
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mb-6">
                  <div class={`w-12 h-12 rounded-xl bg-bg-hover flex items-center justify-center flex-shrink-0`}>
                    <i data-lucide={tier.icon} class={`w-6 h-6 text-accent-${tier.color}`}></i>
                  </div>
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-3">
                      <h3 class="text-2xl font-bold text-text-primary">{tier.name}</h3>
                      <span class="text-lg font-semibold text-accent-coral">{tier.price}<span class="text-sm text-text-muted font-normal">{tier.period}</span></span>
                      {tier.featured && (
                        <span class="px-2 py-0.5 bg-accent-coral text-white text-xs font-bold rounded-full">Popular</span>
                      )}
                      {tier.name === 'Platinum Partner' && (
                        <span class="text-xs px-2 py-0.5 bg-accent-orange/10 text-accent-orange rounded-full">Limited availability</span>
                      )}
                      {tier.name === 'Gold Sponsor' && (
                        <span class="text-xs px-2 py-0.5 bg-accent-orange/10 text-accent-orange rounded-full">Limited availability</span>
                      )}
                      {tier.name === 'Silver Sponsor' && (
                        <span class="text-xs px-2 py-0.5 bg-accent-orange/10 text-accent-orange rounded-full">Limited availability</span>
                      )}
                    </div>
                    {tier.audience && (
                      <p class="text-text-muted text-xs mt-0.5">{tier.audience}</p>
                    )}
                    <p class="text-text-secondary text-sm mt-1">{tier.description}</p>
                  </div>
                  <div class="flex flex-col sm:flex-row gap-2 w-full sm:w-auto">
                    <Button href="https://github.com/sponsors/proyecto26" variant={tier.featured ? 'primary' : 'secondary'} size="sm" class={tier.featured ? 'w-full sm:w-auto' : ''} external>
                      {tier.featured ? 'Become a Silver Sponsor' : 'Sponsor via GitHub'}
                    </Button>
                    <Button href="https://opencollective.com/proyecto26" variant="secondary" size="sm" external>
                      Open Collective
                    </Button>
                  </div>
                </div>

                {/* Benefits */}
                <div class="bg-bg-card border border-border-default rounded-2xl p-6 mb-6">
                  <div class="flex flex-wrap gap-x-8 gap-y-2">
                    {tier.benefits.map((benefit) => (
                      <div class="flex items-center gap-2 text-sm text-text-secondary">
                        <i data-lucide="check" class="w-4 h-4 text-accent-teal flex-shrink-0"></i>
                        {benefit}
                      </div>
                    ))}
                  </div>
                </div>

                {/* Sponsors — logo size varies by tier */}
                {tier.sponsors.length > 0 ? (
                  <div class="flex flex-wrap items-center gap-4">
                    {tier.sponsors.map((sponsor) => (
                      <a
                        href={sponsor.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="group flex items-center gap-3 px-4 py-3 bg-bg-card border border-border-default rounded-xl hover:border-border-accent transition-all duration-200"
                        title={`${sponsor.name}${sponsor.totalDonated ? ` — $${sponsor.totalDonated} contributed` : ''}`}
                      >
                        {sponsor.image ? (
                          <img
                            src={sponsor.image}
                            alt={sponsor.name}
                            width={sizes.w}
                            height={sizes.w}
                            loading="lazy"
                            class={`${sizes.img} rounded-full ring-2 ${sizes.ring}`}
                          />
                        ) : (
                          <div class={`${sizes.img} rounded-full bg-bg-hover flex items-center justify-center text-text-muted font-bold ring-2 ${sizes.ring}`}>
                            {sponsor.name.charAt(0)}
                          </div>
                        )}
                        <span class="text-sm font-medium text-text-primary group-hover:text-accent-coral transition-colors">{sponsor.name}</span>
                      </a>
                    ))}
                  </div>
                ) : isHighTier ? (
                  <div class="bg-bg-card border border-dashed border-border-default rounded-2xl p-6 text-center">
                    <p class="text-text-secondary font-medium mb-3">Interested in {tier.name} sponsorship?</p>
                    <Button href="/contact" variant="secondary" size="sm">
                      <i data-lucide="mail" class="w-4 h-4"></i>
                      Get in Touch
                    </Button>
                  </div>
                ) : (
                  <div class="flex items-center gap-3 text-text-muted text-sm">
                    <div class={`${sizes.img} rounded-full border-2 border-dashed border-border-default flex items-center justify-center`}>
                      <i data-lucide="plus" class="w-4 h-4"></i>
                    </div>
                    <span>Be the first {tier.name} sponsor</span>
                  </div>
                )}

                {tierIndex < sponsorTiers.length - 1 && (
                  <hr class="border-border-default mt-16" />
                )}
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- One-Time Contributions -->
    <section class="py-16 bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4" data-animate="fade-up">
            One-Time Contributions
          </h2>
          <p class="text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Not ready for a monthly commitment? Make a one-time contribution at any level.
          </p>
        </div>

        <!-- Top row: Quick contributions -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-4xl mx-auto mb-6" data-animate="fade-up" data-delay="200">
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="coffee" class="w-5 h-5 text-accent-teal mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$5</span>
            <span class="text-xs text-text-secondary text-center">Buy us a coffee</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="at-sign" class="w-5 h-5 text-accent-blue mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$10</span>
            <span class="text-xs text-text-secondary text-center">X/Twitter shoutout</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="zap" class="w-5 h-5 text-accent-orange mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$25</span>
            <span class="text-xs text-text-secondary text-center">Support a feature</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="file-text" class="w-5 h-5 text-accent-teal mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$50</span>
            <span class="text-xs text-text-secondary text-center">Release notes mention</span>
          </a>
        </div>

        <!-- Bottom row: Premium services -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 max-w-4xl mx-auto" data-animate="fade-up" data-delay="300">
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="rocket" class="w-5 h-5 text-accent-coral mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$100</span>
            <span class="text-xs text-text-secondary text-center">Fund a sprint</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="users" class="w-5 h-5 text-accent-blue mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$200</span>
            <span class="text-xs text-text-secondary text-center">Pair-programming</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="message-circle" class="w-5 h-5 text-accent-orange mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$500</span>
            <span class="text-xs text-text-secondary text-center">1h consulting</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1">
            <i data-lucide="bug" class="w-5 h-5 text-accent-coral mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$1,000</span>
            <span class="text-xs text-text-secondary text-center">Bug bounty</span>
          </a>
          <a href="https://github.com/sponsors/proyecto26" target="_blank" rel="noopener noreferrer"
            class="group flex flex-col items-center p-5 bg-bg-card border border-border-default rounded-2xl hover:border-border-accent transition-all duration-200 hover:-translate-y-1 col-span-2 sm:col-span-1">
            <i data-lucide="mic" class="w-5 h-5 text-accent-teal mb-2"></i>
            <span class="text-xl font-bold text-text-primary">$2,000</span>
            <span class="text-xs text-text-secondary text-center">Conference talk</span>
          </a>
        </div>
      </div>
    </section>

    <!-- All Platforms -->
    <section class="py-16 bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Ways to Sponsor
          </h2>
          <p class="text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Choose the platform that works best for you. All platforms support both recurring and one-time contributions.
          </p>
        </div>

        {/* Primary platforms — full-width cards */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto mb-8">
          <a
            href="https://github.com/sponsors/proyecto26"
            target="_blank"
            rel="noopener noreferrer"
