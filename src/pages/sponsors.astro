<style>
  .gradient-text {
    background: linear-gradient(135deg, var(--color-accent-coral), var(--color-accent-teal));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
    const delay = parseInt(el.getAttribute('data-delay') || '0') / 1000;

    gsap.from(el, {
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.6,
      delay,
      ease: 'power2.out',
    });
  });

  // Sticky sponsor bar — show when hero section scrolls out of view
  const stickyBar = document.getElementById('sticky-sponsor-bar');
  const heroSection = document.querySelector('#main-content > section:first-of-type') as HTMLElement;

  if (stickyBar && heroSection) {
    ScrollTrigger.create({
      trigger: heroSection,
      start: 'bottom top',
      onEnter: () => stickyBar.classList.remove('-translate-y-full'),
      onLeaveBack: () => stickyBar.classList.add('-translate-y-full'),
    });
  }

  // Copy crypto address to clipboard
  const copyBtn = document.getElementById('copy-crypto-btn');
  const copyIcon = document.getElementById('copy-icon');
  const copiedIcon = document.getElementById('copied-icon');

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText('jdnichollsc.eth');
      copyIcon?.classList.add('hidden');
      copiedIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        copiedIcon?.classList.add('hidden');
      }, 2000);
    } catch {
      // Fallback for older browsers
      const textArea = document.createElement('textarea');
      textArea.value = 'jdnichollsc.eth';
      document.body.appendChild(textArea);
      textArea.select();
      document.execCommand('copy');
      document.body.removeChild(textArea);
      copyIcon?.classList.add('hidden');
      copiedIcon?.classList.remove('hidden');
      setTimeout(() => {
        copyIcon?.classList.remove('hidden');
        copiedIcon?.classList.add('hidden');
      }, 2000);
    }
  });
</script>
