---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ServiceCard from '../components/ServiceCard.astro';
import GameCard from '../components/GameCard.astro';
import Button from '../components/Button.astro';
import { getFeaturedProjects } from '../data/projects';
import { getOrgContributors } from '../utils/github';

// Fetch featured projects with GitHub stats at build time
const projects = await getFeaturedProjects(6);

// Fetch top contributors at build time
const contributors = await getOrgContributors('proyecto26', 12);

const services = [
  {
    title: 'Mobile Development',
    description: 'Cross-platform libraries for native mobile experiences.',
    icon: 'smartphone',
    color: 'coral' as const,
    technologies: ['React Native', 'NativeScript', 'Ionic'],
  },
  {
    title: 'Web Components',
    description: 'Framework-agnostic components for modern web apps.',
    icon: 'globe',
    color: 'teal' as const,
    technologies: ['Stencil', 'Web Animations API', 'TypeScript'],
  },
  {
    title: 'Game Development',
    description: 'Tools and plugins for building browser and Unity games.',
    icon: 'gamepad-2',
    color: 'orange' as const,
    technologies: ['Phaser', 'Unity', 'C#'],
  },
];

const games = [
  {
    title: 'NinjaDev',
    description: 'A side-scrolling platformer that showcases advanced game development techniques. Jump, run, and slash your way through challenging levels.',
    tags: ['Phaser', '2D Platformer', 'Action'],
    href: '/games/ninjadev',
    featured: true,
  },
  {
    title: 'The Crypto Purge',
    description: 'Action-packed crypto-themed game adventure.',
    tags: ['Phaser', 'Web3', 'WebSockets'],
    href: 'https://devpost.com/software/the-crypto-purge-jamg3s',
  },
  {
    title: 'PokéDex GO',
    description: 'Community of Pokemon masters, hybrid mobile app created to showcase real-time interactions with Firebase.',
    tags: ['Cordova/Ionic', 'Firebase'],
    href: 'https://github.com/proyecto26/PokeDex-GO',
  },
];

const sponsorTiers = [
  {
    name: 'Beer',
    price: '$2',
    period: '/mo',
    icon: 'coffee',
    color: 'coral',
    description: 'Buy us a beer while we fix the world.',
    benefits: ['Sponsor badge', 'Our eternal gratitude'],
  },
  {
    name: 'Unicorns',
    price: '$10',
    period: '/mo',
    icon: 'sparkles',
    color: 'teal',
    description: 'Become a community contributor.',
    benefits: ['Sponsor badge', 'Bug prioritization', 'Name in projects'],
  },
  {
    name: 'Heroes',
    price: '$26',
    period: '/mo',
    icon: 'shield',
    color: 'orange',
    featured: true,
    description: 'Join us to change the world together.',
    benefits: ['1-on-1 meetings', 'Exclusive content', 'Priority support', 'All previous benefits'],
  },
  {
    name: 'Enterprise',
    price: '$50',
    period: '/mo',
    icon: 'building-2',
    color: 'blue',
    description: 'Professional support for your projects.',
    benefits: ['Hourly consulting', 'Custom examples', 'Live chat support', 'All previous benefits'],
  },
];

const supportLinks = [
  { name: 'Patreon', icon: 'heart', color: '#FF424D', href: 'https://patreon.com/proyecto26' },
  { name: 'Ko-fi', icon: 'coffee', color: '#f2385a', href: 'https://ko-fi.com/proyecto26' },
  { name: 'Open Collective', icon: 'users', color: '#7FADF2', href: 'https://opencollective.com/proyecto26' },
  { name: 'Liberapay', icon: 'dollar-sign', color: '#f6c915', href: 'https://liberapay.com/proyecto26' },
];
---

<BaseLayout title="Proyecto 26 - Changing the world with small contributions">
  <Header currentPage="home" />

  <main id="main-content">
    <!-- Hero Section -->
    <Hero />

    <!-- Projects Section -->
    <section id="projects" class="section bg-bg-primary">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Open Source Tools Developers Love
          </h2>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Building the future of web, mobile, and game development
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
          {projects.map((project, index) => (
            <div data-animate="fade-up" data-delay={index * 100}>
              <ProjectCard {...project} />
            </div>
          ))}
        </div>

        <div class="text-center" data-animate="fade-up" data-delay="600">
          <Button href="https://github.com/proyecto26" variant="secondary" external>
            View All Projects
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </Button>
        </div>
      </div>
    </section>

    <!-- What We Build Section -->
    <section class="section bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            What We Build
          </h2>
          <p class="text-lg text-text-secondary" data-animate="fade-up" data-delay="100">
            Specialized tools and libraries across three core domains
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {services.map((service, index) => (
            <div data-animate="fade-up" data-delay={index * 100}>
              <ServiceCard {...service} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Games Section -->
    <section class="section bg-bg-primary">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Play Our Games
          </h2>
          <p class="text-lg text-text-secondary" data-animate="fade-up" data-delay="100">
            Interactive experiences built with Phaser and other game engines
          </p>
        </div>

        <!-- Featured Game -->
        <div class="mb-12" data-animate="fade-up" data-delay="200">
          <p class="text-xs font-semibold text-accent-coral uppercase tracking-widest mb-4">Featured Game</p>
          <GameCard {...games[0]} />
        </div>

        <!-- More Games -->
        <div class="mb-4">
          <p class="text-xs font-semibold text-text-muted uppercase tracking-widest mb-4">More Games</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {games.slice(1).map((game, index) => (
            <div data-animate="fade-up" data-delay={300 + index * 100}>
              <GameCard {...game} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- About / Founder Section -->
    <section id="about" class="section bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Meet the Founder
          </h2>
        </div>

        <div class="max-w-4xl mx-auto" data-animate="fade-up" data-delay="200">
          <div class="bg-bg-card border border-border-default rounded-3xl p-8 md:p-12">
            <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
              <!-- Photo -->
              <div class="flex-shrink-0">
                <div class="w-48 h-48 rounded-full overflow-hidden ring-4 ring-accent-coral/30">
                  <img
                    src="/img/jdnichollsc.jpg"
                    alt="Juan David Nicholls"
                    width="192"
                    height="192"
                    loading="lazy"
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>

              <!-- Info -->
              <div class="text-center md:text-left">
                <h3 class="text-3xl font-bold text-text-primary mb-2">
                  Juan David Nicholls
                </h3>
                <p class="text-accent-coral font-medium mb-4">
                  Founder & Lead Developer
                </p>
                <p class="text-text-secondary mb-6">
                  Full-Stack Developer and Open Source Contributor with over 14 years of expertise in web, mobile, game, blockchain and cloud development. Skilled in building scalable architectures, seamless user experiences and driving innovation through Open Source. Passionate about sharing knowledge as a speaker and mentor.
                </p>

                <!-- Location -->
                <div class="flex items-center justify-center md:justify-start gap-2 text-text-muted mb-6">
                  <i data-lucide="map-pin" class="w-4 h-4"></i>
                  <span>Based in Colombia</span>
                </div>

                <!-- Social Links -->
                <div class="flex items-center justify-center md:justify-start gap-3">
                  <a
                    href="https://linkedin.com/in/jdnichollsc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-lg bg-bg-hover flex items-center justify-center text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all duration-200"
                  >
                    <i data-lucide="linkedin" class="w-5 h-5"></i>
                  </a>
                  <a
                    href="https://github.com/jdnichollsc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-lg bg-bg-hover flex items-center justify-center text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all duration-200"
                  >
                    <i data-lucide="github" class="w-5 h-5"></i>
                  </a>
                  <a
                    href="https://x.com/jdnichollsc"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-lg bg-bg-hover flex items-center justify-center text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all duration-200"
                  >
                    <i data-lucide="twitter" class="w-5 h-5"></i>
                  </a>
                  <a
                    href="https://youtube.com/@proyecto26"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-10 h-10 rounded-lg bg-bg-hover flex items-center justify-center text-text-secondary hover:text-text-primary hover:bg-bg-tertiary transition-all duration-200"
                  >
                    <i data-lucide="youtube" class="w-5 h-5"></i>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Contributors Section -->
    {contributors.length > 0 && (
      <section class="py-16 bg-bg-primary">
        <div class="container">
          <div class="text-center mb-12">
            <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
              Our Contributors
            </h2>
            <p class="text-lg text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
              Thanks to the developers who help build and improve our projects
            </p>
          </div>

          <div class="flex flex-wrap items-center justify-center gap-4 max-w-3xl mx-auto mb-8" data-animate="fade-up" data-delay="200">
            {contributors.map((contributor) => (
              <a
                href={contributor.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group relative"
                title={`@${contributor.username} (${contributor.contributions} contributions)`}
              >
                <img
                  src={`${contributor.avatar}&s=80`}
                  alt={contributor.username}
                  width="48"
                  height="48"
                  loading="lazy"
                  class="w-12 h-12 rounded-full ring-2 ring-border-default transition-all duration-200 group-hover:ring-accent-coral group-hover:scale-110"
                />
              </a>
            ))}
          </div>

          <div class="text-center" data-animate="fade-up" data-delay="300">
            <Button href="https://github.com/proyecto26" variant="secondary" size="sm" external>
              Become a Contributor
              <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </Button>
          </div>
        </div>
      </section>
    )}

    <!-- Sponsor Tiers Section -->
    <section id="contact" class="section bg-bg-secondary">
      <div class="container">
        <div class="text-center mb-16">
          <h2 class="text-4xl md:text-5xl font-bold text-text-primary mb-4" data-animate="fade-up">
            Become a Sponsor
          </h2>
          <p class="text-lg text-text-secondary max-w-2xl mx-auto" data-animate="fade-up" data-delay="100">
            Help us continue building open source tools for developers worldwide. Every contribution makes a difference.
          </p>
        </div>

        <!-- Sponsor Tiers -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
          {sponsorTiers.map((tier, index) => (
            <div
              class:list={[
                'relative bg-bg-card rounded-2xl p-6 transition-all duration-300 hover:-translate-y-1',
                tier.featured
                  ? 'border-2 border-accent-coral shadow-glow-card'
                  : 'border border-border-default hover:border-border-accent'
              ]}
              data-animate="fade-up"
              data-delay={index * 100}
            >
              {tier.featured && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 bg-accent-coral text-white text-xs font-bold rounded-full">
                  Popular
                </div>
              )}

              <div class={`w-12 h-12 mb-4 rounded-xl bg-bg-hover flex items-center justify-center`}>
                <i data-lucide={tier.icon} class={`w-6 h-6 text-accent-${tier.color}`}></i>
              </div>

              <h3 class="text-lg font-semibold text-text-primary mb-1">{tier.name}</h3>
              <div class="flex items-baseline gap-1 mb-3">
                <span class="text-3xl font-bold text-text-primary">{tier.price}</span>
                <span class="text-text-muted text-sm">{tier.period}</span>
              </div>
              <p class="text-text-secondary text-sm mb-4">{tier.description}</p>

              <ul class="space-y-2 mb-6">
                {tier.benefits.map((benefit) => (
                  <li class="flex items-start gap-2 text-sm text-text-secondary">
                    <i data-lucide="check" class="w-4 h-4 text-accent-teal mt-0.5 flex-shrink-0"></i>
                    {benefit}
                  </li>
                ))}
              </ul>

              <Button
                href="https://github.com/sponsors/proyecto26"
                variant={tier.featured ? 'primary' : 'secondary'}
                size="sm"
                external
              >
                Sponsor
              </Button>
            </div>
          ))}
        </div>

        <!-- More ways to support -->
        <div class="max-w-3xl mx-auto">
          <p class="text-center text-text-muted text-sm mb-6" data-animate="fade-up" data-delay="400">
            Also available on
          </p>
          <div class="flex flex-wrap items-center justify-center gap-4" data-animate="fade-up" data-delay="500">
            {supportLinks.map((link) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 px-4 py-2 bg-bg-card border border-border-default rounded-lg text-text-secondary hover:text-text-primary hover:border-border-accent transition-all duration-200"
              >
                <i data-lucide={link.icon} class="w-4 h-4" style={`color: ${link.color};`}></i>
                <span class="text-sm font-medium">{link.name}</span>
              </a>
            ))}
          </div>

          <!-- GitHub Stars CTA -->
          <div class="text-center mt-12" data-animate="fade-up" data-delay="600">
            <p class="text-text-secondary mb-4">
              Not ready to sponsor? Star our repos — it helps others discover our projects!
            </p>
            <Button href="https://github.com/proyecto26" variant="secondary" external>
              <i data-lucide="star" class="w-4 h-4"></i>
              Star on GitHub
            </Button>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Initialize animations when GSAP is loaded
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Fade up animation for elements with data-animate="fade-up"
  document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
    const delay = parseInt(el.getAttribute('data-delay') || '0') / 1000;

    gsap.from(el, {
      scrollTrigger: {
        trigger: el,
        start: 'top 85%',
        toggleActions: 'play none none none',
      },
      y: 30,
      opacity: 0,
      duration: 0.6,
      delay,
      ease: 'power2.out',
    });
  });

</script>
